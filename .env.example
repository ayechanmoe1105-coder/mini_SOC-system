# Copy to .env and fill in. Never commit .env.

# Database
DATABASE_URL=sqlite:///security_monitoring.db

# OpenAI (optional — AI explanations)
OPENAI_API_KEY=

# Telegram alerts (optional)
TELEGRAM_BOT_TOKEN=
TELEGRAM_CHAT_ID=

# Threat intelligence (optional — set ENABLE_REAL_APIS=true to use)
VIRUSTOTAL_API_KEY=
ABUSEIPDB_API_KEY=
ENABLE_REAL_APIS=false
ENABLE_SEARCH_HISTORY=true
ENABLE_BATCH_SEARCH=true
ENABLE_EXPORT_RESULTS=true

# Flask
FLASK_SECRET_KEY=change-me-in-production
FLASK_ENV=development

# Logs & detection (paths are relative to process CWD unless the app anchors them)
LOG_DIRECTORY=./logs
ENABLE_SYNTHETIC_LOG_GENERATOR=false
SYNTHETIC_LOG_INTERVAL_SECONDS=10
ALERT_THRESHOLD=7.0
SCAN_DETECTION_WINDOW=300
BRUTE_FORCE_THRESHOLD=5
BRUTE_FORCE_WINDOW=60

# Dashboard port — default 15500 (NOT 5000; many other scripts use 5000 and show "SIMPLE TEST")
SOC_PORT=15500
# Set false to stop auto-opening the browser when the server starts
SOC_OPEN_BROWSER=true
